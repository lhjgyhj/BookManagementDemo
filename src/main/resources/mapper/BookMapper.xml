<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lhj.bookmanagementdemo.mapper.BookMapper">
    <update id="updateById">
        update book set name=#{name},description= #{description},cover= #{cover},publisher= #{publisher},publish_date= #{publishDate},category= #{category},book_no= #{bookNo},updatetime=#{updatetime},score= #{score},nums= #{nums} where id=#{id}
    </update>
    <update id="updateNumByNo">
        update book set nums=nums+1 where book_no= #{bookNo}
    </update>
    <delete id="deleteById">
        delete from book where id= #{id}
    </delete>
    <select id="save">
        insert into book(name,description,publish_date,author,publisher,category,book_no,cover,score,nums) values(#{name},#{description},#{publishDate},#{author},#{publisher},#{category},#{bookNo},#{cover},#{score},#{nums})
    </select>
    <select id="getById" resultType="com.lhj.bookmanagementdemo.entity.Book">
        select * from book where id=#{id}
    </select>
    <select id="listByCondition" resultType="com.lhj.bookmanagementdemo.entity.Book">
        select * from book
        <where>
            <if test="name != null and name  != ''">
                and name like concat('%',#{name},'%')
            </if>
            <if test="bookNo != null and bookNo  != ''">
                and book_no =#{bookNo}
            </if>
        </where>
        /*模糊查询，如果什么都不传，则查询所有*/
        order by id asc
    </select>
    <select id="list" resultType="com.lhj.bookmanagementdemo.entity.Book">
        select * from book
        order by id asc
    </select>
    <select id="getByBookNo" resultType="com.lhj.bookmanagementdemo.entity.Book">
    select * from book where book_no = #{bookNo}
</select>
</mapper>