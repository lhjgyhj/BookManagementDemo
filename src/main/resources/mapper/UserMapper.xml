<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lhj.bookmanagementdemo.mapper.UserMapper">
    <update id="updateById">
        update user set name=#{name},username=#{username},age=#{age},sex=#{sex},phone=#{phone},address=#{address},updatetime=#{updatetime},status=#{status},account=#{account} where id=#{id}
    </update>
    <delete id="deleteById">
        delete from user where id=#{id}
    </delete>
    <select id="list" resultType="com.lhj.bookmanagementdemo.entity.User">
        select * from user
    </select>
    <select id="listByCondition" resultType="com.lhj.bookmanagementdemo.entity.User">
        select * from user
        <where>
        <if test="name != null and name  != ''">
            and name like concat('%',#{name},'%')
        </if>
        <if test="phone != null and phone  != ''">
            and phone like concat('%',#{phone},'%')
        </if>
        </where>
        /*模糊查询，如果什么都不传，则查询所有*/
        order by id asc
    </select>
    <select id="save">
        insert into user(name,password,username,age,sex,phone,address,account) values(#{name},#{password},#{username},#{age},#{sex},#{phone},#{address},#{account})
    </select>
    <select id="getById">
        select * from user where id=#{id}
    </select>
    <select id="getByUsernameAndPassword" resultType="com.lhj.bookmanagementdemo.entity.User">
        select * from user where username=#{username} and password=#{password}
    </select>
    <select id="getByUserName">
        select * from user where username=#{username}
    </select>
</mapper>